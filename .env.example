# Bitbucket authentication (required for private repositories)
# Create a token at: https://bitbucket.org/[workspace]/[repo]/admin/access-tokens
BITBUCKET_USERNAME=your-username
BITBUCKET_API_TOKEN=your-api-token

# Ollama local AI review settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=kimi-k2.6:cloud
